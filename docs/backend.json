
{
  "entities": {
    "Propiedad": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Propiedad",
      "type": "object",
      "description": "Represents a rental property managed by the application, including its address and owner information.",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "direccion": { "type": "string" },
        "dpto": { "type": "string" },
        "dueno": { "type": "string" }
      },
      "required": ["id", "nombre", "direccion", "dueno"]
    },
    "Inquilino": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Inquilino",
      "type": "object",
      "description": "Represents a tenant renting a specific property.",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "propiedadId": { "type": "string" },
        "telefono": { "type": "string" },
        "vencimiento": { "type": "string" },
        "estado": { "type": "string" }
      },
      "required": ["id", "nombre", "propiedadId", "vencimiento", "estado"]
    },
    "IndexRecord": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "IndexRecord",
      "type": "object",
      "description": "Historical record of an economic index value for a specific month.",
      "properties": {
        "id": { "type": "string" },
        "month": { "type": "string", "description": "Format YYYY-MM" },
        "type": { "type": "string", "enum": ["ICL", "IPC", "CasaPropia"] },
        "value": { "type": "number" }
      },
      "required": ["id", "month", "type", "value"]
    },
    "Contract": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Contract",
      "type": "object",
      "description": "Detailed rental contract information including economic clauses.",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "propertyId": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "baseRentAmount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "tenantId", "propertyId", "baseRentAmount", "startDate"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "artifacts/{appId}/users/{userId}/propiedades/{propiedadId}",
        "definition": { "entityName": "Propiedad" }
      },
      {
        "path": "artifacts/{appId}/users/{userId}/inquilinos/{inquilinoId}",
        "definition": { "entityName": "Inquilino" }
      },
      {
        "path": "artifacts/{appId}/users/{userId}/contratos/{contratoId}",
        "definition": { "entityName": "Contract" }
      },
      {
        "path": "artifacts/{appId}/users/{userId}/indices/{indexId}",
        "definition": { "entityName": "IndexRecord" }
      }
    ]
  }
}
