
{
  "entities": {
    "Property": {
      "title": "Property",
      "type": "object",
      "description": "Unidad funcional gestionada.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "type": { "type": "string", "enum": ["Departamento", "Casa", "Local", "Cochera", "Oficina", "Depósito", "Terreno"] },
        "usage": { "type": "string", "enum": ["Vivienda", "Comercial", "Profesional", "Industrial"] },
        "status": { "type": "string", "enum": ["Disponible", "Reservada", "Alquilada", "En Mantenimiento"] },
        "squareMeters": { "type": "number" },
        "rooms": { "type": "number" },
        "amenities": { "type": "array", "items": { "type": "string" } },
        "owners": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/OwnerParticipation"
          }
        },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "name", "address", "type", "status", "ownerId"]
    },
    "OwnerParticipation": {
      "title": "OwnerParticipation",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "percentage": { "type": "number" }
      }
    },
    "Person": {
      "title": "Person",
      "type": "object",
      "description": "Entidad para Inquilinos, Propietarios, Garantes y Proveedores.",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Inquilino", "Propietario", "Garante", "Proveedor"] },
        "fullName": { "type": "string" },
        "taxId": { "type": "string", "description": "CUIT/CUIL/DNI" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "bankDetails": {
          "type": "object",
          "properties": {
            "bank": { "type": "string" },
            "cbu": { "type": "string" },
            "alias": { "type": "string" }
          }
        },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "type", "fullName", "taxId", "ownerId"]
    },
    "Contract": {
      "title": "Contract",
      "type": "object",
      "description": "Contrato de locación con lógica de indexación argentina.",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "propertyId": { "type": "string" },
        "guarantorIds": { "type": "array", "items": { "type": "string" } },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "baseRentAmount": { "type": "number" },
        "currentRentAmount": { "type": "number" },
        "currency": { "type": "string", "enum": ["ARS", "USD"] },
        "adjustmentType": { "type": "string", "enum": ["Index", "Percentage", "Scale", "Fixed"] },
        "adjustmentMechanism": { "type": "string", "enum": ["ICL", "IPC", "CasaPropia", "Fixed"] },
        "adjustmentFrequencyMonths": { "type": "number" },
        "lateFeeType": { "type": "string", "enum": ["DailyPercentage", "MonthlyPercentage", "Fixed"] },
        "lateFeeValue": { "type": "number" },
        "status": { "type": "string", "enum": ["Vigente", "Próximo a Vencer", "Finalizado", "Rescindido"] },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "tenantId", "propertyId", "baseRentAmount", "currency", "ownerId"]
    },
    "MaintenanceRecord": {
      "title": "MaintenanceRecord",
      "type": "object",
      "description": "Ticket de mantenimiento o reparación.",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "contractId": { "type": "string" },
        "concept": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["Baja", "Media", "Alta", "Crítica"] },
        "status": { "type": "string", "enum": ["Pendiente", "Presupuestado", "En curso", "Completado", "Cerrado"] },
        "providerId": { "type": "string" },
        "estimatedCost": { "type": "number" },
        "actualCost": { "type": "number" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "propertyId", "concept", "priority", "status", "ownerId"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/artifacts/{appId}/users/{userId}/properties/{propertyId}": {
      "schema": { "$ref": "#/backend/entities/Property" },
      "description": "Colección de propiedades."
    },
    "/artifacts/{appId}/users/{userId}/contracts/{contractId}": {
      "schema": { "$ref": "#/backend/entities/Contract" },
      "description": "Contratos de alquiler."
    },
    "/artifacts/{appId}/users/{userId}/people/{personId}": {
      "schema": { "$ref": "#/backend/entities/Person" },
      "description": "Inquilinos, Propietarios, Garantes y Proveedores."
    },
    "/artifacts/{appId}/users/{userId}/maintenanceRecords/{recordId}": {
      "schema": { "$ref": "#/backend/entities/MaintenanceRecord" },
      "description": "Tickets de mantenimiento."
    }
  }
}
