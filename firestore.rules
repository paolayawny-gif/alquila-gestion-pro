rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Super Admin: solo el UID de paolayawny@gmail.com puede leer/escribir
    function isSuperAdmin() {
      return isSignedIn() && request.auth.uid == 'wYkBqQjJuSdQu7F20eFAHZ0qX9N2';
    }

    // ── Super Admin: gestión global de organizaciones y usuarios ─────────────
    match /artifacts/{appId}/superadmin/data/organizations/{orgId} {
      allow read, write: if isSuperAdmin();
    }

    match /artifacts/{appId}/superadmin/data/org_users/{userId} {
      allow read, write: if isSuperAdmin();
    }

    // Regla comodín superadmin (cubre cualquier colección futura)
    match /artifacts/{appId}/superadmin/{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // ── Colecciones por usuario ───────────────────────────────────────────────

    // Regla pública: cualquiera puede ver propiedades (para postulantes)
    match /artifacts/{appId}/users/{userId}/propiedades/{propiedadId} {
      allow get: if true;
      allow list, create, update, delete: if isOwner(userId);
    }

    // Regla pública: cualquiera puede crear solicitudes (buzón de entrada)
    match /artifacts/{appId}/users/{userId}/solicitudes/{solicitudId} {
      allow create: if true;
      allow get, list, update, delete: if isOwner(userId);
    }

    // Regla comodín: cubre todas las demás colecciones del usuario
    match /artifacts/{appId}/users/{userId}/{collection}/{docId} {
      allow read, write: if isOwner(userId);
    }
  }
}
