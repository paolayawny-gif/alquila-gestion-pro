rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DOCUMENTATION: PROP-ADMIN SECURITY MODEL
     *
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model. Every piece of data—from properties 
     * and tenants to invoices and legal cases—is nested within a user-specific path. 
     * Security is primary derived from the {userId} parameter in the document path.
     *
     * Data Structure:
     * All data is organized under the hierarchy: /artifacts/{appId}/users/{userId}/{collection}/{docId}.
     * This ensures that one user's data is physically and logically separated from another's.
     *
     * Key Security Decisions:
     * 1. Path-Based Authorization: We rely on the userId in the path matching the 
     *    authenticated user's UID (request.auth.uid). This is the fastest and most secure 
     *    method for user-owned data.
     * 2. No Public Access: All collections are private. There are no public read or list operations.
     * 3. Identity Anchoring: During document creation, we ensure the internal 'id' field 
     *    of the document matches the Firestore Document ID to maintain relational integrity.
     * 4. Immutable Identity: Once a document is created, its 'id' field is made immutable 
     *    to prevent accidental or malicious re-parenting.
     *
     * Denormalization for Authorization:
     * The ownership (userId) is "denormalized" directly into the URL path. This avoids 
     * costly get() lookups on parent documents and allows for efficient, scalable rules.
     */

    // --- Helper Functions ---

    /**
     * @description Checks if a user is authenticated with a valid Firebase Auth token.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Verifies if the authenticated user matches the owner of the path.
     * @param userId The UID extracted from the document path.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Combines ownership check with a check for document existence.
     * Used for update and delete operations to ensure the target exists and is owned.
     * @param userId The UID extracted from the document path.
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Security rules for the Propiedad collection.
     * @path /artifacts/{appId}/users/{userId}/propiedades/{propiedadId}
     * @allow (get, list, create, update, delete) if the authenticated user's UID matches {userId}.
     * @deny (all) if the user is not logged in or tries to access another user's property data.
     * @principle Restricts access to a user's own data tree and validates document ID consistency.
     */
    match /artifacts/{appId}/users/{userId}/propiedades/{propiedadId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == propiedadId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Security rules for the Inquilino collection.
     * @path /artifacts/{appId}/users/{userId}/inquilinos/{inquilinoId}
     * @allow (create) if the user is the owner and the provided 'id' matches the document path ID.
     * @deny (update) if the request attempts to change the internal 'id' field.
     * @principle Enforces document ownership and relational consistency between path and data.
     */
    match /artifacts/{appId}/users/{userId}/inquilinos/{inquilinoId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == inquilinoId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Security rules for the Factura collection.
     * @path /artifacts/{appId}/users/{userId}/facturas/{facturaId}
     * @allow (list) for the owner to retrieve their list of invoices.
     * @deny (delete) if the document does not exist or belongs to another user.
     * @principle Ensures financial records are isolated and protected by path-based ownership.
     */
    match /artifacts/{appId}/users/{userId}/facturas/{facturaId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == facturaId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Security rules for the Mantenimiento collection.
     * @path /artifacts/{appId}/users/{userId}/mantenimiento/{mantenimientoId}
     * @allow (update) if the owner modifies maintenance details without changing the ID.
     * @deny (create) if the userId in the path does not match the authenticated UID.
     * @principle Restricts maintenance tracking data to the authenticated creator.
     */
    match /artifacts/{appId}/users/{userId}/mantenimiento/{mantenimientoId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == mantenimientoId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Security rules for the LegalCase collection.
     * @path /artifacts/{appId}/users/{userId}/legalCases/{legalCaseId}
     * @allow (get) for the owner to view specific legal case details.
     * @deny (list) if an unauthenticated user attempts to query the collection.
     * @principle Protects sensitive legal information through strict user-isolation.
     */
    match /artifacts/{appId}/users/{userId}/legalCases/{legalCaseId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == legalCaseId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Security rules for the Liquidacion collection.
     * @path /artifacts/{appId}/users/{userId}/liquidaciones/{liquidacionId}
     * @allow (create) if the owner creates a settlement record with a matching ID.
     * @deny (delete) if the requester's UID does not match the path's userId.
     * @principle Enforces ownership for settlement reports and ensures data path integrity.
     */
    match /artifacts/{appId}/users/{userId}/liquidaciones/{liquidacionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == liquidacionId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }
  }
}