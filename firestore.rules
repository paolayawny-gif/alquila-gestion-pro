rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PROTYPING MODE SECURITY RULES
     * 
     * Core Philosophy: 
     * This ruleset enforces a strict user-ownership model. Access is strictly compartmentalized 
     * by the User ID (UID) provided by Firebase Authentication.
     * 
     * Data Structure: 
     * Data is organized hierarchically under /artifacts/{appId}/users/{userId}/. 
     * Every document is expected to contain an 'ownerId' field that matches the {userId} in the path.
     * 
     * Key Security Decisions:
     * 1. Authorization Independence: We use denormalized 'ownerId' fields on every document 
     *    to allow for immediate, high-performance authorization without requiring costly get() 
     *    lookups of parent documents.
     * 2. Structural Segregation: By nesting all data under a userId-specific path, we 
     *    ensure that list operations (queries) are naturally scoped to the authenticated user.
     * 3. Immutability: Critical relational fields, specifically 'ownerId', are immutable 
     *    once a document is created to prevent "ownership hijacking."
     * 4. Prototyping Flexibility: While authorization is strict (who can access), 
     *    data shape validation is relaxed (what is inside) to support rapid development.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Combines ownership check with existence check for destructive operations. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /** @description Validates that the ownerId field in the new data matches the authorized user. */
    function isValidOwnership(userId) {
      return request.resource.data.ownerId == userId;
    }

    /** @description Ensures the ownerId field cannot be changed during an update. */
    function isOwnershipImmutable() {
      return request.resource.data.ownerId == resource.data.ownerId;
    }

    // --- Collection Rules ---

    match /artifacts/{appId}/users/{userId} {
      
      /**
       * @description Rules for Property documents.
       * @path /artifacts/{appId}/users/{userId}/properties/{propertyId}
       * @allow (create) if authenticated as {userId} and ownerId in data matches {userId}.
       * @deny (get) if authenticated as a different user.
       * @principle Restricts property management to the authenticated owner via path and data consistency.
       */
      match /properties/{propertyId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidOwnership(userId);
        allow update: if isExistingOwner(userId) && isOwnershipImmutable();
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for Tenant documents.
       * @path /artifacts/{appId}/users/{userId}/tenants/{tenantId}
       * @allow (list) if authenticated as {userId}.
       * @deny (update) if attempting to change the 'ownerId' field.
       * @principle Enforces private tenant database per user.
       */
      match /tenants/{tenantId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidOwnership(userId);
        allow update: if isExistingOwner(userId) && isOwnershipImmutable();
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for Contract documents.
       * @path /artifacts/{appId}/users/{userId}/contracts/{contractId}
       * @allow (update) if user owns the document and does not modify ownerId.
       * @deny (delete) if document does not exist or user is not the owner.
       * @principle Secures legal rental agreements through strict path-based ownership.
       */
      match /contracts/{contractId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidOwnership(userId);
        allow update: if isExistingOwner(userId) && isOwnershipImmutable();
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for Invoice documents.
       * @path /artifacts/{appId}/users/{userId}/invoices/{invoiceId}
       * @allow (get) if user is the owner.
       * @deny (create) if user tries to set an ownerId different from their auth UID.
       * @principle Protects financial billing data from cross-user access.
       */
      match /invoices/{invoiceId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidOwnership(userId);
        allow update: if isExistingOwner(userId) && isOwnershipImmutable();
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for MaintenanceRecord documents.
       * @path /artifacts/{appId}/users/{userId}/maintenanceRecords/{recordId}
       * @allow (create) if path userId matches auth UID.
       * @deny (list) if requesting data from another user's subcollection.
       * @principle Ensures maintenance logs are only accessible to the managing user.
       */
      match /maintenanceRecords/{recordId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidOwnership(userId);
        allow update: if isExistingOwner(userId) && isOwnershipImmutable();
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for LegalCase documents.
       * @path /artifacts/{appId}/users/{userId}/legalCases/{caseId}
       * @allow (delete) if user is owner and document exists.
       * @deny (get) for unauthenticated users.
       * @principle Safeguards sensitive legal and mediation information.
       */
      match /legalCases/{caseId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidOwnership(userId);
        allow update: if isExistingOwner(userId) && isOwnershipImmutable();
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for Liquidation (financial settlement) documents.
       * @path /artifacts/{appId}/users/{userId}/liquidations/{liquidationId}
       * @allow (update) if ownerId remains unchanged.
       * @deny (list) for anonymous users unless UID matches path.
       * @principle Restricts owner payout reports to the authorized manager.
       */
      match /liquidations/{liquidationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidOwnership(userId);
        allow update: if isExistingOwner(userId) && isOwnershipImmutable();
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}